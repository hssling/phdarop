# ─── PHDAROP web app environment ────────────────────────────────────────────
# The app is fully functional WITHOUT any keys: the analytical core (MCDA,
# optimization, attribution, gap indices) is deterministic TypeScript and always
# runs. AI keys only enrich question-understanding and the policy-brief narrative.

# Vercel AI Gateway (recommended): one key, many providers.
# Get it from the Vercel dashboard → AI Gateway. When deployed on Vercel with
# OIDC, this is injected automatically and you can leave it blank.
AI_GATEWAY_API_KEY=

# Model id routed through the AI Gateway ("provider/model"). Optional.
# Examples: anthropic/claude-sonnet-4.5 · openai/gpt-4o-mini · google/gemini-2.0-flash
PHDA_MODEL=anthropic/claude-sonnet-4.5

# Set to "1" to force deterministic mode (no AI calls at all).
PHDA_DETERMINISTIC=0
